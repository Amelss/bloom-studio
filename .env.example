# Bloom Studio — environment
# Copy this file to `.env` (git-ignored) and fill in from your Supabase project:
#   Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: serve flower assets from a Supabase Storage public bucket (CDN)
# instead of the app bundle. Leave unset for local dev. See docs/ASSET-CLOUD.md.
# VITE_ASSET_BASE_URL=https://your-project-ref.supabase.co/storage/v1/object/public/flower-assets
